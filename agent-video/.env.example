# DemoClaw / agent-video environment.
# Nothing here is strictly required: with no credentials the server defaults to
# free/local providers (edge TTS + local file output). Set what you need.

# --- Narration (LLM) ---
# claude (default):
ANTHROPIC_API_KEY=
# openai-compatible (covers DeepSeek, vLLM, Ollama, ...). Select via providers
# config: { narration: { name: "openai", baseUrl, model, apiKeyEnv } }
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- TTS ---
# elevenlabs (char-level timing tier):
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# edge (free, duration timing tier) - run via uvx by default, override if needed:
# EDGE_TTS_CMD=uvx edge-tts
# EDGE_TTS_VOICE=en-US-AriaNeural
# miso (deferred local 8B model; only on capable hardware, e.g. M2 Ultra):
# MISO_TTS_CMD=uv run python run_misotts.py
# MISO_TTS_VOICE_REF=/path/to/reference-voice.wav

# --- Video host ---
# mux:
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# local (default on-device; optional copy destination):
# DEMOCLAW_LOCAL_OUTPUT_DIR=
# s3-compatible (AWS S3, R2, MinIO, ...):
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=democlaw/
# S3_PUBLIC_BASE_URL=

# --- Default provider overrides (optional) ---
# DEMOCLAW_NARRATION_PROVIDER=claude
# DEMOCLAW_TTS_PROVIDER=edge
# DEMOCLAW_HOST_PROVIDER=local
# DEMOCLAW_POSTPROD_PROVIDER=ffmpeg   # or openscreen for final polish (requires playwright)
# DEMOCLAW_POSTPROD_PRESET=demo-with-cursor   # demo-default | demo-with-cursor | fast
# AEGIS demo manifest (aegis-demo.json) defaults to openscreen + demo-with-cursor.

# --- Tooling overrides (optional) ---
# AGENT_BROWSER_BIN=agent-browser
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
# OpenScreen polish: npm install && npx playwright install chromium
